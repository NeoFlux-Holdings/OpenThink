{
  "name": "@open-think/starter-personal-agent",
  "version": "0.3.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "vite build --outDir dist/client --emptyOutDir",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "dev": "vite build --outDir dist/client --emptyOutDir && wrangler dev --config wrangler.agents-sdk.jsonc",
    "deploy": "vite build --outDir dist/client --emptyOutDir && wrangler deploy --config wrangler.agents-sdk.jsonc"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.0",
    "@open-think/core": "workspace:*",
    "@open-think/llm": "workspace:*",
    "@open-think/mcp": "workspace:*",
    "@open-think/retrieval": "workspace:*",
    "@open-think/storage": "workspace:*",
    "@open-think/tasks": "workspace:*",
    "@open-think/terminal": "workspace:*",
    "@cloudflare/ai-chat": "^0.6.2",
    "agents": "^0.12.3",
    "ai": "^6.0.174",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "streamdown": "^2.5.0",
    "zod": "^4.4.2",
    "workers-ai-provider": "^3.1.13"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "vite": "latest",
    "wrangler": "latest"
  }
}
