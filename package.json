{
  "name": "open-think",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@10.7.0",
  "description": "Cloudflare-native Personal Agent OS monorepo.",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build && pnpm --filter @open-think/platform build",
    "dev": "pnpm --filter @open-think/platform dev",
    "docs:dev": "pnpm --filter @open-think/docs dev",
    "test": "vitest run --passWithNoTests",
    "typecheck": "pnpm -r --filter './packages/*' build && pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@types/node": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
